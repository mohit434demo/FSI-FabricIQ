model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["DirectLake - lh_insurance"]

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["RemoteModeling","DirectLakeOnOneLakeCreatedInDesktop","DevMode","DirectLakeOnOneLakeInWeb","WebModelingEdit"]

ref table offices
ref table policyholders
ref table insured_assets
ref table adjusters
ref table policies
ref table claims
ref table claim_events
ref table asset_inspections

